  window.addEventListener('DOMContentLoaded', () => {
    lucide.createIcons();
    const stored = localStorage.getItem('samarpan-theme') || 'light';
    document.documentElement.setAttribute('data-theme', stored);
    if (stored === 'dark') { document.getElementById('themeIcon')?.setAttribute('data-lucide','sun'); lucide.createIcons(); }
    // Fade-up observer
    const obs = new IntersectionObserver(entries => entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); }), {threshold:.07});
    document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
    // Prefill session from URL param
    const params = new URLSearchParams(window.location.search);
    if (params.get('session')) {
      const target = [...document.querySelectorAll('.sess-opt')].find(el => el.dataset.session === decodeURIComponent(params.get('session')));
      if (target) { document.querySelectorAll('.sess-opt').forEach(e=>e.classList.remove('selected')); target.classList.add('selected'); state.session = { name:target.dataset.session, price:target.dataset.price, duration:target.dataset.duration, category:target.dataset.category }; }
    }
    buildCalendar();
  });

  /* ── SCROLL ── */
  window.addEventListener('scroll', () => {
    const sp = document.getElementById('scroll-progress');
    if (sp) sp.style.width = Math.min((window.scrollY/(document.body.scrollHeight-window.innerHeight))*100,100)+'%';
    const show = window.scrollY > 200;
    document.getElementById('whatsapp-fab')?.classList.toggle('visible',show);
    document.getElementById('theme-toggle')?.classList.toggle('visible',show);
  },{passive:true});

