  <style>
    :root{--bg:#FDFBF7;--bg2:#F9F7F4;--bg3:#FFFFFF;--text:#1C1C1C;--text-muted:#666666;--border:#e8e4de;--card-bg:#FFFFFF;--nav-bg:rgba(253,251,247,0.97);}
    [data-theme="dark"]{--bg:#141410;--bg2:#1A1A16;--bg3:#1F1F1B;--text:#F0EDE6;--text-muted:#9A9080;--border:#2E2E28;--card-bg:#1F1F1B;--nav-bg:rgba(20,20,16,0.96);}
    *,*::before,*::after{box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background-color:var(--bg);color:var(--text);overflow-x:hidden;-webkit-font-smoothing:antialiased;transition:background-color .4s,color .4s;}

    #scroll-progress{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#D95D39,#C5A059);z-index:10000;width:0%;transition:width .1s linear;}

    /* NAV */
    #navbar{position:fixed;left:0;width:100%;z-index:100;height:72px;display:flex;align-items:center;top:0;background:var(--nav-bg);border-bottom:1px solid var(--border);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:background .4s;}
    .nav-link{position:relative;font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-family:'Lato',sans-serif;font-weight:700;transition:color .3s;color:var(--text-muted);text-decoration:none;}
    .nav-link:hover,.nav-link.active{color:var(--text);}
    .nav-link::after{content:'';position:absolute;bottom:-3px;left:0;right:0;height:1px;background:#D95D39;transform:scaleX(0);transform-origin:left;transition:transform .3s;}
    .nav-link:hover::after,.nav-link.active::after{transform:scaleX(1);}
    .nav-logo-text{font-family:'Marcellus',serif;font-size:11px;letter-spacing:.28em;text-transform:uppercase;font-weight:700;color:var(--text);}
    .nav-cta-btn{display:inline-block;padding:.65rem 1.4rem;background:#D95D39;color:#fff!important;font-family:'Lato',sans-serif;font-size:9.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;border:none;cursor:pointer;transition:background .3s,box-shadow .3s,transform .2s;text-decoration:none;border-radius:2px;white-space:nowrap;}
    .nav-cta-btn:hover{background:#c24e2c;box-shadow:0 6px 20px rgba(217,93,57,.45);transform:translateY(-1px);}
    #mobile-menu{position:fixed;inset:0;z-index:200;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.75rem;opacity:0;visibility:hidden;pointer-events:none;transition:opacity .35s,visibility .35s;}
    #mobile-menu.active{opacity:1;visibility:visible;pointer-events:auto;}

    /* PROGRESS STEPPER */
    .stepper{display:flex;align-items:center;gap:0;}
    .step-node{display:flex;flex-direction:column;align-items:center;gap:.35rem;position:relative;}
    .step-circle{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Lato',sans-serif;font-size:11px;font-weight:700;border:2px solid var(--border);background:var(--bg2);color:var(--text-muted);transition:all .4s cubic-bezier(.34,1.56,.64,1);}
    .step-circle.active{background:#D95D39;border-color:#D95D39;color:#fff;transform:scale(1.15);box-shadow:0 4px 16px rgba(217,93,57,.35);}
    .step-circle.done{background:#4A5D4F;border-color:#4A5D4F;color:#fff;}
    .step-label{font-family:'Lato',sans-serif;font-size:8px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);white-space:nowrap;}
    .step-label.active{color:#D95D39;}
    .step-label.done{color:#4A5D4F;}
    .step-line{flex:1;height:1px;background:var(--border);margin:0 6px;margin-bottom:18px;transition:background .4s;}
    .step-line.done{background:#4A5D4F;}

    /* SESSION OPTION CARDS */
    .sess-opt{border:1.5px solid var(--border);border-radius:6px;padding:1.25rem 1.5rem;cursor:pointer;transition:all .3s;display:flex;align-items:flex-start;gap:1rem;background:var(--card-bg);}
    .sess-opt:hover{border-color:#D95D39;box-shadow:0 8px 28px rgba(217,93,57,.08);}
    .sess-opt.selected{border-color:#D95D39;background:rgba(217,93,57,.03);box-shadow:0 8px 28px rgba(217,93,57,.12);}
    .sess-opt.selected .sess-radio{background:#D95D39;border-color:#D95D39;}
    .sess-opt.selected .sess-radio::after{opacity:1;}
    .sess-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;margin-top:3px;position:relative;transition:all .25s;}
    .sess-radio::after{content:'';position:absolute;inset:3px;border-radius:50%;background:#fff;opacity:0;transition:opacity .2s;}
    .sess-tag{font-family:'Lato',sans-serif;font-size:8px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:.2rem .55rem;border-radius:2px;display:inline-block;margin-bottom:.35rem;}
    .sess-price{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:#D95D39;line-height:1;}
    .sess-price.free{color:#4A5D4F;}
    .sess-duration{font-family:'Lato',sans-serif;font-size:9px;color:var(--text-muted);letter-spacing:.1em;text-transform:uppercase;}
    .popular-pill{display:inline-flex;align-items:center;gap:.3rem;background:rgba(217,93,57,.1);border:1px solid rgba(217,93,57,.2);border-radius:50px;padding:.15rem .6rem;font-family:'Lato',sans-serif;font-size:8px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#D95D39;margin-left:.5rem;}

    /* FORM */
    .form-label{display:block;font-family:'Lato',sans-serif;font-size:9px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;color:var(--text-muted);margin-bottom:.5rem;}
    .form-input{width:100%;background:var(--bg2);border:1.5px solid var(--border);border-radius:4px;padding:.85rem 1rem;font-size:.875rem;font-family:'Lato',sans-serif;color:var(--text);outline:none;transition:border-color .3s,box-shadow .3s;resize:none;}
    .form-input:focus{border-color:#C5A059;box-shadow:0 0 0 3px rgba(197,160,89,.1);}
    .form-input::placeholder{color:var(--text-muted);opacity:.55;}
    .form-input.error{border-color:#ef4444;}
    .field-error{font-family:'Lato',sans-serif;font-size:10px;color:#ef4444;margin-top:.3rem;display:none;}
    .field-error.show{display:block;}

    /* TIME SLOT GRID */
    .slot-btn{font-family:'Lato',sans-serif;font-size:10px;font-weight:700;letter-spacing:.1em;padding:.55rem .9rem;border:1.5px solid var(--border);border-radius:4px;background:var(--card-bg);color:var(--text-muted);cursor:pointer;transition:all .25s;text-align:center;}
    .slot-btn:hover:not(:disabled){border-color:#D95D39;color:#D95D39;}
    .slot-btn.selected{background:#D95D39;border-color:#D95D39;color:#fff;}
    .slot-btn:disabled{opacity:.35;cursor:not-allowed;text-decoration:line-through;}

    /* CONCERN CHIPS */
    .chip{display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .9rem;border:1.5px solid var(--border);border-radius:50px;font-family:'Lato',sans-serif;font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--text-muted);cursor:pointer;transition:all .25s;background:transparent;white-space:nowrap;}
    .chip:hover{border-color:#D95D39;color:#D95D39;}
    .chip.selected{background:#D95D39;border-color:#D95D39;color:#fff;}

    /* SUMMARY CARD */
    .summary-row{display:flex;justify-content:space-between;align-items:flex-start;padding:.75rem 0;border-bottom:1px solid var(--border);gap:1rem;}
    .summary-row:last-child{border-bottom:none;}
    .summary-key{font-family:'Lato',sans-serif;font-size:9px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);}
    .summary-val{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--text);text-align:right;}

    /* STEP PANELS */
    .step-panel{display:none;animation:fadeSlide .4s ease;}
    .step-panel.active{display:block;}
    @keyframes fadeSlide{from{opacity:0;transform:translateX(16px);}to{opacity:1;transform:translateX(0);}}

    /* CALENDAR */
    .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:.3rem;}
    .cal-day{height:36px;display:flex;align-items:center;justify-content:center;font-family:'Lato',sans-serif;font-size:.75rem;font-weight:700;border-radius:4px;cursor:pointer;border:1.5px solid transparent;transition:all .2s;}
    .cal-day.empty{cursor:default;}
    .cal-day.past{color:var(--border);cursor:not-allowed;}
    .cal-day.available:hover{border-color:#D95D39;color:#D95D39;}
    .cal-day.selected{background:#D95D39;color:#fff!important;border-color:#D95D39;}
    .cal-day.today{border-color:rgba(197,160,89,.5);color:#C5A059;}
    .cal-header{font-family:'Lato',sans-serif;font-size:8px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);height:28px;display:flex;align-items:center;justify-content:center;}

    /* CTA BTN */
    .cta-btn{position:relative;overflow:hidden;transition:background .3s,box-shadow .3s,transform .2s;cursor:pointer;}
    .cta-btn:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(217,93,57,.3);}

    /* SIDEBAR */
    .sidebar-feature{display:flex;align-items:flex-start;gap:.75rem;padding:.9rem 0;border-bottom:1px solid var(--border);}
    .sidebar-feature:last-child{border-bottom:none;}

    /* FLOATING */
    #whatsapp-fab{position:fixed;bottom:2rem;right:1.5rem;z-index:900;opacity:0;transform:translateY(20px);transition:opacity .4s,transform .4s;}
    #whatsapp-fab.visible{opacity:1;transform:translateY(0);}
    #whatsapp-fab a{display:flex;align-items:center;justify-content:center;width:48px;height:48px;background:#25D366;color:#fff;border-radius:50%;box-shadow:0 6px 24px rgba(37,211,102,.45);text-decoration:none;transition:transform .3s;}
    #whatsapp-fab a:hover{transform:scale(1.1);}
    #theme-toggle{position:fixed;bottom:2rem;left:1.5rem;z-index:900;opacity:0;transform:translateY(20px);transition:opacity .4s,transform .4s;}
    #theme-toggle.visible{opacity:1;transform:translateY(0);}
    #theme-toggle button{display:flex;align-items:center;justify-content:center;width:44px;height:44px;background:var(--card-bg);border:1px solid var(--border);border-radius:50%;cursor:pointer;color:var(--text);transition:background .3s,transform .3s;}
    #theme-toggle button:hover{transform:scale(1.1);background:#D95D39;color:#fff;}

    /* FADE UP */
    .fade-up{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease;}
    .fade-up.visible{opacity:1;transform:translateY(0);}

    /* SUCCESS */
    @keyframes successPop{0%{transform:scale(0) rotate(-10deg);}60%{transform:scale(1.15) rotate(3deg);}100%{transform:scale(1) rotate(0);}}
    .success-icon{animation:successPop .6s cubic-bezier(.34,1.56,.64,1) forwards;}

    /* GOLD RULE */
    .gold-rule{width:48px;height:2px;background:linear-gradient(90deg,#D95D39,#C5A059);margin:1rem 0;}

    ::-webkit-scrollbar{width:5px;}
    ::-webkit-scrollbar-track{background:var(--bg);}
    ::-webkit-scrollbar-thumb{background:#D95D39;border-radius:4px;}
  </style>
</head>
