    for(let i=1;i<=4;i++){
      const sc=document.getElementById('sc-'+i);
      const sl=document.getElementById('sl-'+i);
      if (i<active){
        sc.className='step-circle done';
        sc.innerHTML='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
        sl.className='step-label done';
      } else if (i===active){
        sc.className='step-circle active';
        sc.textContent=i;
        sl.className='step-label active';
      } else {
        sc.className='step-circle';
        sc.textContent=i;
        sl.className='step-label';
      }
      if(i<4){
        const ln=document.getElementById('line-'+i);
        ln.className='step-line'+(i<active?' done':'');
      }
    }
    lucide.createIcons();
  }

  /* ── SELECT SESSION ── */
  function selectSession(el){
    document.querySelectorAll('.sess-opt').forEach(e=>e.classList.remove('selected'));
    el.classList.add('selected');
    state.session = { name:el.dataset.session, price:el.dataset.price, duration:el.dataset.duration, category:el.dataset.category };
  }

  /* ── SELECT MODE ── */
  function selectMode(mode){
    state.mode=mode;
    ['online','inperson'].forEach(id=>{
      const el=document.getElementById('mode-'+id);
      const r=document.getElementById('mr-'+id);
      if((id==='online'&&mode==='online')||(id==='inperson'&&mode==='in-person')){
        el.classList.add('selected'); r.classList.add('selected');
      } else {
        el.classList.remove('selected'); r.classList.remove('selected');
      }
    });
  }

  /* ── CALENDAR ── */
  const MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  let calYear, calMonth;

  function buildCalendar(){
    const now=new Date();
    calYear=now.getFullYear();
    calMonth=now.getMonth();
    renderCalendar();
  }

  function renderCalendar(){
    document.getElementById('calMonthLabel').textContent=MONTHS[calMonth]+' '+calYear;
    // Headers
    const hd=document.getElementById('calHeaders');
    hd.innerHTML=DAYS.map(d=>`<div class="cal-header">${d}</div>`).join('');
    // Days
    const gd=document.getElementById('calDays');
    gd.innerHTML='';
    const first=new Date(calYear,calMonth,1).getDay();
    const daysInMonth=new Date(calYear,calMonth+1,0).getDate();
    const today=new Date(); today.setHours(0,0,0,0);
    const todayStr=fmt(today);
    // Empty cells
    for(let i=0;i<first;i++) gd.innerHTML+=`<div class="cal-day empty"></div>`;
    // Day cells
    for(let d=1;d<=daysInMonth;d++){
      const dt=new Date(calYear,calMonth,d);
      const dtStr=fmt(dt);
      const isPast=dt<today;
      const isSun=dt.getDay()===0;
      const isToday=dtStr===todayStr;
      const isSelected=state.date===dtStr;
      let cls='cal-day';
      if(isPast||isSun) cls+=' past';
      else cls+=' available';
      if(isToday&&!isPast&&!isSun) cls+=' today';
      if(isSelected) cls+=' selected';
      const onclick=(isPast||isSun)?'':`onclick="selectDate('${dtStr}',this)"`;
      gd.innerHTML+=`<div class="${cls}" ${onclick}>${d}</div>`;
    }
    // Update prev button
    const now=new Date(); 
    document.getElementById('prevMonthBtn').disabled=(calYear===now.getFullYear()&&calMonth<=now.getMonth());
    lucide.createIcons();
  }

  function fmt(d){ return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }

  function prevMonth(){
    if(calMonth===0){calYear--;calMonth=11;}else calMonth--;
    renderCalendar();
  }
  function nextMonth(){
    if(calMonth===11){calYear++;calMonth=0;}else calMonth++;
    renderCalendar();
  }

  function selectDate(dateStr, el){
    state.date=dateStr;
    document.querySelectorAll('.cal-day.available').forEach(d=>d.classList.remove('selected'));
    el.classList.add('selected');
    const [y,m,d]=dateStr.split('-');
    const niceDateStr=`${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;
    document.getElementById('selectedDateLabel').textContent='— '+niceDateStr;
    document.getElementById('dateError').classList.remove('show');
  }

  /* ── TIME SLOTS ── */
  function selectSlot(el,val){
    document.querySelectorAll('.slot-btn').forEach(s=>s.classList.remove('selected'));
    el.classList.add('selected');
    state.slot=val;
    document.getElementById('slotError').classList.remove('show');
  }

  /* ── CHIPS ── */
  function toggleChip(el){ el.classList.toggle('selected'); }

  /* ── VALIDATE STEP 2 ── */
  function validateStep2(){
    let ok=true;
    if(!state.date){ document.getElementById('dateError').classList.add('show'); ok=false; }
    if(!state.slot){ document.getElementById('slotError').classList.add('show'); ok=false; }
    state.timezone=document.getElementById('timezone').value;
    if(ok) goStep(3);
  }

  /* ── VALIDATE STEP 3 ── */
  function validateStep3(){
    let ok=true;
    const checks=[
      {id:'f-name', errId:'err-name', test:v=>v.length>0},
      {id:'f-email', errId:'err-email', test:v=>v.includes('@')&&v.includes('.')},
      {id:'f-phone', errId:'err-phone', test:v=>v.length>5},
      {id:'f-intention', errId:'err-intention', test:v=>v.length>0}
    ];
    checks.forEach(c=>{
      const el=document.getElementById(c.id);
      const err=document.getElementById(c.errId);
      if(!c.test(el.value.trim())){
        el.classList.add('error'); err.classList.add('show'); ok=false;
      } else {
        el.classList.remove('error'); err.classList.remove('show');
      }
    });
    if(ok) goStep(4);
  }

  /* ── BUILD REVIEW ── */
  function buildReview(){
    const concerns=[...document.querySelectorAll('.chip.selected')].map(c=>c.textContent.trim());
    const [y,m,d]=state.date.split('-');
    const niceDateStr=`${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;
    const rows=[
      ['Session', state.session.name],
      ['Price', state.session.price],
      ['Duration', state.session.duration],
      ['Mode', state.mode==='online'?'Online via Zoom':'In-Person · New Delhi'],
      ['Date', niceDateStr],
      ['Time', state.slot+' (IST)'],
      ['Timezone', state.timezone],
      ['Name', document.getElementById('f-name').value.trim()],
      ['Email', document.getElementById('f-email').value.trim()],
      ['Phone', document.getElementById('f-phone').value.trim()],
      ['Concerns', concerns.length?concerns.join(', '):'—'],
    ];
    document.getElementById('reviewSummary').innerHTML=rows.map(([k,v])=>`
      <div class="summary-row">
        <span class="summary-key">${k}</span>
        <span class="summary-val">${v}</span>
      </div>
    `).join('');
  }

  /* ── SUBMIT ── */
  async function submitBooking(){
    const termsEl=document.getElementById('f-terms');
    const errTerms=document.getElementById('err-terms');
    const statusEl=document.getElementById('submitStatus');
    const btnEl=document.getElementById('submitBtn');

    if(!termsEl.checked){ errTerms.classList.add('show'); return; }
    errTerms.classList.remove('show');

    btnEl.disabled=true;
    btnEl.innerHTML='<svg class="animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-opacity=".25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/></svg> Sending…';
    statusEl.textContent='';

    const name      = document.getElementById('f-name').value.trim();
    const email     = document.getElementById('f-email').value.trim();
    const phone     = document.getElementById('f-phone').value.trim();
    const age       = document.getElementById('f-age').value;
    const gender    = document.getElementById('f-gender').value;
    const country   = document.getElementById('f-country').value.trim();
    const intention = document.getElementById('f-intention').value.trim();
    const health    = document.getElementById('f-health').value.trim();
    const source    = document.getElementById('f-source').value;
    const language  = document.getElementById('f-language').value;
    const notes     = document.getElementById('f-notes').value.trim();
    const nl        = document.getElementById('f-newsletter').checked;
    const concerns  = [...document.querySelectorAll('.chip.selected')].map(c=>c.textContent.trim());

    const [y,m,d]=state.date.split('-');
    const niceDateStr=`${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;

    const bookingData = {
      // Client
      client_name: name,
      email,
      phone,
      age_range: age || 'not_specified',
      gender: gender || 'not_specified',
      country: country || 'not_specified',
      language_preference: language,
      // Session
      session_name: state.session.name,
      session_price: state.session.price,
      session_duration: state.session.duration,
      session_category: state.session.category,
      // Schedule
      preferred_mode: state.mode,
      preferred_date: state.date,
      preferred_date_readable: niceDateStr,
      preferred_time: state.slot,
      timezone: state.timezone,
      // Medical
      primary_concerns: concerns,
      intention,
      health_notes: health || 'none',
      additional_notes: notes || 'none',
      // Meta
      referral_source: source || 'not_specified',
      newsletter_opted: nl
    };

    try {
      if (window.saveFullBooking) await window.saveFullBooking(bookingData);
      if (nl && window.saveNewsletter) await window.saveNewsletter(email, name);
    } catch(e) {
      console.warn("Firebase error (non-blocking):", e);
    }

    // Show success overlay
    document.getElementById('successName').textContent=name;
    document.getElementById('successSession').textContent=state.session.name;
    const overlay=document.getElementById('successOverlay');
    overlay.style.display='flex';
    document.body.style.overflow='hidden';
    lucide.createIcons();

    if (typeof gaEvent!=='undefined') gaEvent('booking_complete','Booking',state.session.name);
  }

  /* ── KEYBOARD ── */
  document.addEventListener('keydown', e => {
    if(e.key==='Escape'&&menuOpen) toggleMenu();
  });
</script>
